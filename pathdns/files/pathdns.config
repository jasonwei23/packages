
config pathdns 'main'
	# Disabled by default: pathdns listens for DNS the same way dnsmasq
	# does, so enabling it without adjusting bind.port/dnsmasq first can
	# create a port-53 conflict. Review /etc/pathdns/config.json, then:
	#   uci set pathdns.main.enabled='1'
	#   uci commit pathdns
	#   /etc/init.d/pathdns enable
	#   /etc/init.d/pathdns start
	option enabled '0'

	# JSON configuration file (see https://github.com/jasonwei23/pathdns
	# for the full config reference: bind, route, cache, dashboard, runtime).
	option config_file '/etc/pathdns/config.json'

	# procd service tuning; defaults match pathdns' own upstream examples.
	option user 'root'
	option respawn_threshold '3600'
	option respawn_timeout '5'
	option respawn_retry '5'
	option file_limit '65535'
