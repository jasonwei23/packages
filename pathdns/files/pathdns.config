
config pathdns 'main'
	# Disabled by default: pathdns listens for DNS the same way dnsmasq
	# does, so enabling it without adjusting bind.port/dnsmasq first can
	# create a port-53 conflict. Review /etc/pathdns/config.json, then:
	#   uci set pathdns.main.enabled='1'
	#   uci commit pathdns
	#   /etc/init.d/pathdns enable
	#   /etc/init.d/pathdns start
	option enabled '0'

	# JSON configuration file (see https://github.com/jasonwei23/pathdns
	# for the full config reference: bind, route, cache, dashboard, runtime).
	option config_file '/etc/pathdns/config.json'

	# User pathdns runs as. Leave as 'root': it needs raw sockets, netlink
	# (ipset/nftset) and io_uring, none of which work unprivileged.
	option user 'root'

	# Transparently redirect all tcp/udp port-53 traffic on the router to
	# pathdns (nftables DNAT), so LAN clients are forced through it no
	# matter which DNS server they're configured to use. The redirect
	# target port is auto-detected from config_file's "bind".port.
	option redirect_dns '0'
